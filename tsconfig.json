{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "paths": {
      "react-native-s-pen": ["./src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["android", "ios", "example", "node_modules"]
}
